if {Thaw.gloomberry_count} >= 1.0:
	join Echofall (Echofall Sit In Throne) center
	Echofall: ...
	Echofall: You have come to kill me?
	Echofall: I can see you have the seeds.
	Echofall (Echofall Mad): Let's end this
	set {Thaw.echofall_defeated} = false
elif {Thaw.gloomberry_count} < 1.0:
	join Echofall (Echofall Sit In Throne) center
	Echofall: ...
	Echofall: Scram.